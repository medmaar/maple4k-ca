# Static assets — 1 year immutable cache
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML — revalidate hourly
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# Homepage — push hero image as early as possible via HTTP Link header
/
  Cache-Control: public, max-age=3600, must-revalidate
  Link: </hero-mobile.webp>; rel=preload; as=image; type="image/webp"; media="(max-width: 828px)"
  Link: </hero-desktop.webp>; rel=preload; as=image; type="image/webp"; media="(min-width: 829px)"

/index.html
  Cache-Control: public, max-age=3600, must-revalidate
  Link: </hero-mobile.webp>; rel=preload; as=image; type="image/webp"; media="(max-width: 828px)"
  Link: </hero-desktop.webp>; rel=preload; as=image; type="image/webp"; media="(min-width: 829px)"

# Security headers on all routes
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block

# Disable Cloudflare email obfuscation on all pages
# This prevents injection of email-decode.min.js
/*
  X-Clacks-Overhead: GNU Terry Pratchett
